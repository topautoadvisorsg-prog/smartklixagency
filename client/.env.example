# Formspree Configuration
# Get your form endpoint from https://formspree.io
# Format: https://formspree.io/f/YOUR_FORM_ID
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID

# Tidio Chat Configuration
# Get your public key from Tidio Settings > Developer
VITE_TIDIO_PUBLIC_KEY=your_tidio_public_key_here
